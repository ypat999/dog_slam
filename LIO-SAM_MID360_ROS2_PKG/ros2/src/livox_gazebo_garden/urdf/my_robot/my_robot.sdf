<?xml version="1.0" ?>
<sdf version='1.9'>
  <model name='mid360_robot'>
    <link name='base_footprint'>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0.04 0 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01</iyy>
          <iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      
      <collision name='base_link_collision'>
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.1 0.08</size>
          </box>
        </geometry>
      </collision>
      
      <visual name='base_link_visual'>
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.1 0.08</size>
          </box>
        </geometry>
        <material>
          <diffuse>1 1 1 0.5</diffuse>
          <ambient>1 1 1 0.5</ambient>
        </material>
      </visual>
    </link>

    <link name='livox_frame'>
      <pose>0.07 0 0.14 0 0.5236 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia>
          <ixx>0.0004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0004</iyy>
          <iyz>0</iyz>
          <izz>0.0004</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      
      <visual name='livox_frame_visual'>
        <geometry>
          <mesh>
            <uri>package://livox_gazebo_garden/meshes/mid-360-scaled.dae</uri>
          </mesh>
        </geometry>
      </visual>
      
      <collision name='livox_frame_collision'>
        <geometry>
          <box>
            <size>0.088 0.088 0.04</size>
          </box>
        </geometry>
      </collision>

      <sensor name='mid360_lidar' type='gpu_lidar'>
        <topic>livox/lidar</topic>
        <frame_id>livox_frame</frame_id>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.1415926</min_angle>
              <max_angle>3.1415926</max_angle>
            </horizontal>
            <vertical>
              <samples>60</samples>
              <resolution>1</resolution>
              <min_angle>-0.126012</min_angle>
              <max_angle>0.963771</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>100.0</max>
            <resolution>0.005</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.002</stddev>
          </noise>
        </ray>
      </sensor>

      <sensor name='mid360_imu' type='imu'>
        <topic>livox/imu</topic>
        <frame_id>livox_frame</frame_id>
        <update_rate>200</update_rate>
        <always_on>true</always_on>
        <imu>
          <angular_velocity>
            <x>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <joint name='livox_frame_joint' type='fixed'>
      <parent>base_footprint</parent>
      <child>livox_frame</child>
    </joint>

    <link name='behind_left_wheel'>
      <pose>-0.08 0.07 0.04 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01</iyy>
          <iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name='behind_left_wheel_collision'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='behind_left_wheel_visual'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='behind_left_wheel_joint' type='revolute'>
      <parent>base_footprint</parent>
      <child>behind_left_wheel</child>
      <pose>-0.08 0.07 0.04 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
      </axis>
    </joint>

    <link name='behind_right_wheel'>
      <pose>-0.08 -0.07 0.04 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01</iyy>
          <iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name='behind_right_wheel_collision'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='behind_right_wheel_visual'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='behind_right_wheel_joint' type='revolute'>
      <parent>base_footprint</parent>
      <child>behind_right_wheel</child>
      <pose>-0.08 -0.07 0.04 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
      </axis>
    </joint>

    <link name='ahead_left_wheel'>
      <pose>0.08 0.07 0.04 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01</iyy>
          <iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name='ahead_left_wheel_collision'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='ahead_left_wheel_visual'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='ahead_left_wheel_joint' type='revolute'>
      <parent>base_footprint</parent>
      <child>ahead_left_wheel</child>
      <pose>0.08 0.07 0.04 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
      </axis>
    </joint>

    <link name='ahead_right_wheel'>
      <pose>0.08 -0.07 0.04 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01</iyy>
          <iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name='ahead_right_wheel_collision'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
      </collision>
      <visual name='ahead_right_wheel_visual'>
        <pose>0 0 0 1.57079 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.032</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <joint name='ahead_right_wheel_joint' type='revolute'>
      <parent>base_footprint</parent>
      <child>ahead_right_wheel</child>
      <pose>0.08 -0.07 0.04 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
      </axis>
    </joint>

    <plugin name='gz::sim::systems::DiffDrive' filename='gz-sim-diff-drive-system'>
      <left_joint>behind_left_wheel_joint</left_joint>
      <right_joint>behind_right_wheel_joint</right_joint>
      <wheel_separation>0.14</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <topic>/cmd_vel</topic>
    </plugin>
  </model>
</sdf>
