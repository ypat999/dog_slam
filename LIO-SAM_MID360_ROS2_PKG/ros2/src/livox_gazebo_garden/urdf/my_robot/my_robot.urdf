  <!-- =============== 导入gazebo插件 ============ -->
  <!-- =============== 使用插件 ============ -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>behind_left_wheel_joint</left_joint>
      <right_joint>behind_right_wheel_joint</right_joint>
      <wheel_separation>0.14</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <topic>/cmd_vel</topic>
    </plugin>
  </gazebo>
