# =============================================================================
# NAV2 Configuration - Merged Beam & Likelihood Model
# =============================================================================
# 使用说明：
# 1. 取消注释需要的模型参数块，注释掉另一个模型
# 2. Beam模型适用于结构化环境，Likelihood模型适用于非结构化环境
# 3. 两个模型共享MPPI控制器和其他模块配置
# =============================================================================

# =============================================================================
# Controller Server Configuration - MPPI 控制器
# =============================================================================
# Controller Server 实现了处理控制器请求的服务器，并托管一个插件实现映射。它接收路径以及
# 控制器、进度检查器和目标检查器的插件名称，调用相应的插件。它还托管本地代价图（local costmap）。
# =============================================================================
controller_server:
  ros__parameters:
    bond_disable_heartbeat_timeout: true  
    # 是否使用仿真时间
    use_sim_time: false

    # 控制器运行参数
    # 控制器运行频率（Hz）
    controller_frequency: 20.0
    # 代价图完全更新后计算控制指令的超时时间（s）
    costmap_update_timeout: 0.3
    # 为控制器服务器添加软实时优先级，将控制器执行线程设为更高优先级（90），确保调度截止时间。需在 /etc/security/limits.conf 中设置 <username> softrtprio 99
    use_realtime_priority: false
    # 目标退出时是否发布零速度命令，用于在目标终止时停止机器人
    publish_zero_velocity: true

    # 速度阈值 - 控制器服务器过滤里程计速度，低于此阈值的值将设为 0.0
    # X 方向线速度最小阈值（m/s），低于此的输出置零
    min_x_velocity_threshold: 0.1
    # Y 方向线速度最小阈值（m/s）
    min_y_velocity_threshold: 0.1
    # 角速度最小阈值（rad/s）
    min_theta_velocity_threshold: 0.1

    # 容错与里程计
    # 被调用控制器插件连续失败（computeVelocityCommands 抛出异常）的最大持续时间（s），-1.0 无限，0 禁用
    failure_tolerance: 3.0
    # 获取瞬时速度测量的里程计话题
    odom_topic: "/rkbot/lio/odom"
    # 缓冲里程计命令以估计机器人速度的时间（s）
    odom_duration: 0.3

    # 速度限制话题
    # 要订阅的速度限制话题名称，可由 Speed Filter 发布，也可由外部服务器提供
    speed_limit_topic: "/speed_limit"

    # 路径搜索窗口
    # 搜索算法沿路径向前查找最近点的距离（m）
    search_window: 2.0

    # 速度命令类型
    # 是否使用 geometry_msgs::msg::TwistStamped（true）或 Twist（false）。Kilted 及更新版本默认 true，Jazzy 及更旧版本默认 false
    enable_stamped_cmd_vel: true

    # 系统配置
    # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true
    
    # 插件配置
    # 映射的控制器插件名称列表，用于处理请求和参数
    controller_plugins: ["FollowPath"]
    # 映射的目标检查器插件名称，用于检查目标是否到达
    goal_checker_plugins: ["goal_checker"]
    # 进度检查器插件名（Humble 及更旧版本使用单字符串插件）
    progress_checker_plugin: "progress_checker"
    # 映射的路径处理器插件名称，用于处理规划器路径
    path_handler_plugins: ["PathHandler"]
    
    # 进度检查器参数 - 配合新行为树优化
    progress_checker:
      # 进度检查器插件类型
      plugin: "nav2_controller::SimpleProgressChecker"
      # 判定为有进展所需的最小移动半径（m）
      required_movement_radius: 0.10
      # 无进展超时时间（s）
      movement_time_allowance: 20.0
    
    # 目标检查器参数 - 优化终点减速和停止精度
    goal_checker:
      # 目标检查器插件类型
      plugin: "nav2_controller::StoppedGoalChecker"
      # 到达目标的 XY 位置容差（m）
      xy_goal_tolerance: 0.3
      # 到达目标的朝向容差（rad）
      yaw_goal_tolerance: 0.2
      # 判定为停止的线速度阈值（m/s）
      trans_stopped_velocity: 1.5
      # 判定为停止的角速度阈值（rad/s）
      rot_stopped_velocity: 1.5
      # 是否启用有状态检查（到达后不再重新评估）
      stateful: true

    # 路径处理器参数
    PathHandler:
      # 路径处理器插件类型
      plugin: "nav2_controller::FeasiblePathHandler"

    # MPPI控制器参数 - 全向移动配置（实时性优化）
    FollowPath:
      # 控制器插件类型
      plugin: "nav2_mppi_controller::MPPIController"

      # 轨迹时间步数
      time_steps: 32
      # 每个时间步的时长（s），time_steps * model_dt = 预测时域
      model_dt: 0.1
      # 每轮采样的候选轨迹数量
      batch_size: 1000
      # TF 变换容差（s）
      transform_tolerance: 0.5

      # 最大前向速度（m/s）
      vx_max: 2.0
      # 最大反向速度（m/s）
      vx_min: -0.4
      # 前向速度采样标准差
      vx_std: 1.0
      # 最大横向速度（m/s，Omni 模型）
      vy_max: 0.4
      # 横向速度采样标准差
      vy_std: 0.4
      # 角速度采样标准差
      wz_std: 1.0
      # 最大角速度（rad/s）
      wz_max: 1.5
      
      # 温度参数
      # 轨迹选择敏锐度，越小越倾向于最低代价轨迹
      temperature: 0.2
      # motion_model: "DiffDrive" 
      # 运动模型：DiffDrive / Omni / Ackermann
      motion_model: "Omni"
      # 重置优化器的非活跃超时时间（s），Humble only
      reset_period: 0.5

      # 加速度限制
      # 最大前向加速度（m/s^2）
      ax_max: 1.0
      # 最大减速度（m/s^2）
      ax_min: -1.0
      # 最大横向加速度（m/s^2，Omni 模型有效）
      ay_max: 0.5
      # 最小横向加速度（m/s^2，Omni 模型有效）
      ay_min: -0.5
      # 最大角加速度（rad/s^2）
      az_max: 1.5

      # 滤波器与控制模式
      # Savitzky-Golay 滤波器阶数（1 或 2），用于平滑控制序列
      sgf_order: 2
      # 是否使用开环控制（false=闭环，使用里程计反馈）
      open_loop: false

      # 可视化与调试
      # 是否发布调试轨迹可视化
      visualize: false
      # 是否发布最优轨迹（含位姿、速度、时间戳）
      publish_optimal_trajectory: false
      # 可视化指定评价器的代价（0=全部代价，1-N=对应评价器）
      critic_index_to_visualize: 0
      # 是否每轮重新生成噪声（false=复用初始噪声，减少计算抖动）
      regenerate_noises: false

      # TrajectoryVisualizer参数
      TrajectoryVisualizer:
        # 轨迹可视化时每 N 个时间步取一点
        time_step: 5
        # 轨迹可视化时每 N 条候选轨迹显示一条
        trajectory_step: 20

      # 是否强制路径反转（机器人掉头时反向跟踪路径）
      enforce_path_inversion: true
      # 路径反转的 XY 容差（m）
      inversion_xy_tolerance: 0.3
      # 路径反转的朝向容差（rad）
      inversion_yaw_tolerance: 0.4
      # 平滑度与能量的权衡系数（高=平滑，低=节能），参见 MPPI 论文
      gamma: 0.015
      # MPPI 迭代次数，建议保持 1 并增大 batch_size
      iteration_count: 1
      # 从最近路径点向前裁剪路径的距离（m），应与预测时域成比例
      prune_distance: 2.0
      # 搜索路径最近点时沿路径向前搜索的最大距离（m）
      max_robot_pose_search_dist: 2.0
      # 失败后重试次数（软重置）
      retry_attempt_limit: 3
  
      # 评价器参数 - 优化权重以提高停止精度
      # 启用的评价器列表
      critics: ["ConstraintCritic", "CostCritic",  "PathFollowCritic", "GoalCritic", "PreferForwardCritic", "GoalAngleCritic", "VelocityDeadbandCritic", "ObstaclesCritic", "PathAngleCritic", "TwirlingCritic",  "PathAlignCritic"]

      # =====================================================
      # ConstraintCritic - 约束评价器
      # =====================================================
      # 用于强制执行可行约束的评价器目标函数。惩罚具有超出设定动力学或运动学约束分量的轨迹。
      # =====================================================
      ConstraintCritic:
        # 是否启用
        enabled: true
        # 代价幂次
        cost_power: 1
        # 评价器权重
        cost_weight: 10.0
      
      # =====================================================
      # CostCritic - 代价图评价器
      # =====================================================
      # 激励远离障碍物和临界碰撞，使用圆形机器人点检查或基于代价图值的完整 SE2 足迹检查。
      # =====================================================
      CostCritic:
        # 是否启用
        enabled: true
        # 评价器权重（内部会除以 254 归一化）
        cost_weight: 5.0
        # 代价幂次
        cost_power: 1
        # 近碰撞区域惩罚代价（>= near_collision_cost 时触发）
        critical_cost: 300.0
        # 近碰撞代价阈值
        near_collision_cost: 253
        # 真实碰撞代价值
        collision_cost: 254.0
        # 是否使用完整 footprint 碰撞检测（false=使用圆心点）
        consider_footprint: false
        # 接近目标时停止避障偏好项的距离（m）
        near_goal_distance: 0.5
        # 膨胀层名称（为空则使用最后一个膨胀层）
        inflation_layer_name: ""
        # 轨迹点采样步长
        trajectory_point_step: 2

      # =====================================================
      # ObstaclesCritic - 障碍物评价器
      # =====================================================
      # 激励远离障碍物和临界碰撞，使用圆形机器人点检查或基于障碍物距离的完整 SE2 足迹检查。
      # =====================================================
      ObstaclesCritic:
        # 是否启用
        enabled: true
        # 代价幂次
        cost_power: 2
        # 是否使用 SE2 footprint 碰撞检测
        consider_footprint: true
        # 近碰撞区域（collision_margin_distance 内）的惩罚权重
        critical_weight: 100.0
        # 一般避障偏好权重（inflation_radius 内），鼓励轨迹远离障碍物
        repulsion_weight: 10.0
        # 真实碰撞代价值
        collision_cost: 254.0
        # 碰撞临界距离（m），类似 footprint 膨胀
        collision_margin_distance: 0.2
        # 接近目标时停止避障偏好项的距离（m），使机器人可平滑收敛到目标
        near_goal_distance: 1.0
        # 膨胀层名称（为空则使用最后一个膨胀层）
        inflation_layer_name: "inflation_layer_local"
        # 障碍物周围膨胀半径（m），应与代价图膨胀层一致，Humble only
        inflation_radius: 0.5
        # 跨膨胀半径的指数衰减因子，应与代价图膨胀层一致，Humble only
        cost_scaling_factor: 10.0
      
      # =====================================================
      # PathFollowCritic - 路径跟随评价器
      # =====================================================
      # 用于近似跟随路径的评价器目标函数。允许在动态障碍物情况下偏离路径。
      # PathAlign 用于更精确地将轨迹对齐到路径上。较高的权重和 offset > 1
      # 会加速样本达到全速并推进跟随点，产生一些捷径行为。
      # =====================================================
      PathFollowCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 40.0
        # 代价幂次
        cost_power: 2
        # 从最远路径点算起的偏移量
        offset_from_furthest: 2
        # 距目标距离小于此值时停止路径跟随，交予目标评价器
        threshold_to_consider: 1.0

      # =====================================================
      # PathAlignCritic - 路径对齐评价器
      # =====================================================
      # 用于对齐路径的评价器目标函数。注意：较高的设置会更精确地跟随路径，
      # 但也使在动态障碍物存在时难以（或不可能）偏离。这是一个重要的评价器，
      # 需要与 Obstacle 评价器一起调优和考虑。
      # =====================================================
      PathAlignCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 10.0
        # 代价幂次
        cost_power: 1
        # 路径占用比例上限
        max_path_occupancy_ratio: 0.07
        # 是否使用路径朝向
        use_path_orientations: true
        # 轨迹点采样步长
        trajectory_point_step: 4
        # 从最远路径点算起的偏移量
        offset_from_furthest: 2
        # 距目标距离小于此值时停止路径跟随
        threshold_to_consider: 1.0

      # =====================================================
      # PathAngleCritic - 路径角度评价器
      # =====================================================
      # 用于在极端未对齐或转向情况下对齐路径的评价器目标函数。
      # mode: 0=FORWARD_PREFERENCE(前进偏好), 1=NO_DIRECTIONAL_PREFERENCE(无方向偏好),
      #       2=CONSIDER_FEASIBLE_PATH_ORIENTATIONS(考虑可行路径朝向)
      # =====================================================
      PathAngleCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 10.0
        # 代价幂次
        cost_power: 1
        # 模式：0=前进偏好, 1=无方向偏好, 2=考虑可行路径朝向
        mode: 0
        # 从最远路径点算起的偏移量
        offset_from_furthest: 2
        # 距目标距离小于此值时停止路径跟随
        threshold_to_consider: 1.5
        # 与最远路径点的最大角度差（rad）
        max_angle_to_furthest: 0.5

      # =====================================================
      # PreferForwardCritic - 前向偏好评价器
      # =====================================================
      # 用于偏好前进运动的评价器目标函数。
      # =====================================================
      PreferForwardCritic:
        # 是否启用
        enabled: true
        # 代价幂次
        cost_power: 1
        # 评价器权重
        cost_weight: 10.0
        # 距目标距离小于此值时停止路径跟随
        threshold_to_consider: 1.5

      # =====================================================
      # TwirlingCritic - 绕圈运动评价器
      # =====================================================
      # 用于惩罚摆动/绕圈运动的评价器目标函数。
      # =====================================================
      TwirlingCritic:
        # 是否启用
        enabled: true
        # 代价幂次
        cost_power: 1
        # 评价器权重
        cost_weight: 10.0

      # =====================================================
      # VelocityDeadbandCritic - 速度死区评价器
      # =====================================================
      # 用于强制执行可行约束的评价器目标函数。
      # =====================================================
      VelocityDeadbandCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 50.0
        # 代价幂次
        cost_power: 1
        # 速度死区 [vx, vy, wz]，低于此的速度被忽略
        deadband_velocities: [0.1, 0.1, 0.1]
      
      # =====================================================
      # GoalCritic - 目标评价器
      # =====================================================
      # 激励在合理接近目标时在空间上向目标导航。
      # =====================================================
      GoalCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 20.0
        # 代价幂次
        cost_power: 1
        # 距目标小于此值时开始考虑目标距离代价
        threshold_to_consider: 2.0

      # =====================================================
      # GoalAngleCritic - 目标角度评价器
      # =====================================================
      # 激励在合理接近目标时导航以达到目标位姿的角度。
      # =====================================================
      GoalAngleCritic:
        # 是否启用
        enabled: true
        # 评价器权重
        cost_weight: 20.0
        # 代价幂次
        cost_power: 1
        # 距目标小于此值时开始考虑目标朝向代价（m）
        threshold_to_consider: 1.0
        # 是否启用对称目标朝向接受。启用时评价器偏好以目标朝向或目标朝向+180°接近目标的轨迹，适用于两端都有传感器的对称机器人
        symmetric_yaw_tolerance: false


# =============================================================================
# Velocity Smoother Configuration - 速度平滑器
# =============================================================================
# nav2_velocity_smoother 是一个包含生命周期组件节点的包，用于平滑 Nav2 发送给机器人控制器
# 的速度命令。其目的是实现速度、加速度和死区平滑，以减少机器人电机和硬件控制器的磨损，
# 消除某些局部轨迹规划器可能产生的加速/急动运动。它还可以以比控制器服务器发布更高的
# 频率插值速度命令。
# =============================================================================
velocity_smoother:
  ros__parameters:
    
    # 是否使用仿真时间
    use_sim_time: false

    # 平滑器核心参数
    # 使用最后收到的速度命令按速度、加速度和死区约束进行平滑的频率（Hz）。若设为局部轨迹规划器频率，应平滑加速度约束；若设得更高，将插值并生成平滑命令
    smoothing_frequency: 40.0
    # 是否按比例调整速度其他分量以匹配加速度限制导致的变化，使所有分量沿同一方向调整，但仍强制执行加速度限制
    scale_velocities: false
    # 反馈类型：OPEN_LOOP 使用上次命令速度作为当前速度；CLOSED_LOOP 使用 odom 话题里程计估计当前速度。闭环模式下里程计需高频率、低延迟
    feedback: "OPEN_LOOP"
    # 为速度平滑器添加软实时优先级，将执行线程设为更高优先级（90），确保调度截止时间
    use_realtime_priority: false

    # 里程计配置
    # 闭环模式下查找里程计的话题
    odom_topic: "/rkbot/lio/odom"
    # 缓冲里程计命令以估计机器人速度的时间（s），仅 CLOSED_LOOP 模式有效
    odom_duration: 0.1
    
    # 速度限制 - 各轴最大/最小速度（m/s, rad/s），格式 [x, y, theta]
    # 各轴最大速度 [vx, vy, vtheta]
    max_velocity: [5.0, 1.5, 5.0]
    # 各轴最小速度 [vx, vy, vtheta]。此为有符号值，负值表示反向。旋转速度负方向为右转
    min_velocity: [-1.0, -1.5, -5.0]
    
    # 加速度限制
    # 各轴最大加速度 [ax, ay, atheta]
    max_accel: [5.0, 2.0, 0.5]
    # 各轴最大减速度 [ax, ay, atheta]。此为有符号值，通常应为负数
    max_decel: [-5.0, -2.0, -2.0]
    
    # 死区与超时
    # 各轴最小速度死区 [vx, vy, vtheta]，低于此值不发送给硬件控制器，防止小命令因堵转扭矩而损坏硬件
    deadband_velocity: [0.1, 0.1, 0.1]
    # 速度超时时间（s），超过此时间无新命令则发送归零 Twist 命令并停止发布
    velocity_timeout: 1.0

    # 速度命令类型
    # 是否使用 geometry_msgs::msg::TwistStamped（true）或 Twist（false）。Kilted 及更新版本默认 true，Jazzy 及更旧版本默认 false
    enable_stamped_cmd_vel: true
    # 是否对平滑后的 TwistStamped cmd_vel 消息的时间戳进行插值（Jazzy 补丁版本中可用）
    stamp_smoothed_velocity_with_smoothing_time: false

    # 系统配置
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true
    
    # qos_overrides:
    #   /tf:
    #     subscription:
    #       depth: 1
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "best_effort"
    #   /tf_static:
    #     subscription:
    #       depth: 1
    #       durability: "transient_local"
    #       history: "keep_last"
    #       reliability: "reliable"


# =============================================================================
# Planner Server Configuration - 规划器服务器
# =============================================================================
# Planner Server 实现了处理规划请求的服务器，并托管一个插件实现映射。它接收目标点和规划器
# 插件名称，调用相应插件计算到达目标的路径。它还托管全局代价图（global costmap）。
# =============================================================================
planner_server:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false
    # 期望规划频率（Hz），若当前频率低于此值则显示警告
    expected_planner_frequency: 0.2
    # 规划请求前代价图完全更新的超时时间（s）
    costmap_update_timeout: 1.0
    # 是否允许规划器在穿过位姿规划时，遇到障碍物时输出部分路径。默认情况下规划失败并中止规划请求
    allow_partial_planning: false
    # 映射的规划器插件名称列表，用于参数和处理请求
    planner_plugins: ["LatticeBased", "GridBased", "HybridBased"]

    # 系统配置
    # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true

    LatticeBased:
      # 规划器插件类型
      plugin: "nav2_smac_planner/SmacPlannerLattice"
      # 无法精确到达目标时的容差（m），用于接受近似路径的终点
      tolerance: 0.3
      # 是否允许在未知空间中搜索路径
      allow_unknown: false
      # 最大搜索迭代次数，-1 表示不限制
      max_iterations: 8000000
      # 进入容差范围后继续尝试精确匹配的最大迭代次数
      max_on_approach_iterations: 100000
      # 规划器最大规划时间（s）
      max_planning_time: 10.0
      # 检查目标取消或规划超时的迭代间隔
      terminal_checking_interval: 5000
      # 尝试解析展开的频率比例，值越大越频繁尝试直接用曲线到达目标
      analytic_expansion_ratio: 3.5
      # 解析展开的最大长度（m），防止从远处抄近路穿过高代价区域
      analytic_expansion_max_length: 3.0
      # 解析展开路径中允许的最大单点代价值，超过则认为无效（接近目标时除外）
      analytic_expansion_max_cost: 200.0
      # 在关键距离内是否覆盖最大代价限制（接近目标时允许高代价展开）
      analytic_expansion_max_cost_override: false
      # 倒车搜索的惩罚系数（仅 allow_reverse_expansion=true 时有效）
      reverse_penalty: 1.0
      # 切换方向（如左转→右转）的惩罚系数
      change_penalty: 0.3
      # 非直线运动的惩罚系数
      non_straight_penalty: 9.0
      # 对高代价区域的惩罚系数，使搜索避开障碍物
      cost_penalty: 1.5
      # 原地旋转的惩罚系数，应足够高以避免非必要原地旋转
      rotation_penalty: 5.0
      # 偏好后期转向的惩罚系数，节省搜索时间（0.0=完全可纳，1.0=最大偏好）
      retrospective_penalty: 0.015
      # 状态格控制集文件路径
      lattice_filepath: "/home/ztl/dog_slam/LIO-SAM_MID360_ROS2_PKG/ros2/src/nav2_dog_slam/config/lattice_primitives.json"
      # Dubin/Reeds-Sheep 距离窗口缓存大小（m）
      lookup_table_size: 20.0
      # 缓存障碍物距离启发式，加速同一目标的重规划（静态地图时效果显著）
      cache_obstacle_heuristic: true
      # 是否允许使用倒车原语进行搜索
      allow_reverse_expansion: false
      # 下采样障碍物启发式代价图以加速搜索（略微降低路径质量）
      downsample_obstacle_heuristic: true
      # 使用二次代价而非线性代价，加速搜索但路径更接近障碍物
      use_quadratic_cost_penalty: false
      # 目标朝向模式：DEFAULT=使用请求朝向，BIDIRECTIONAL=同时尝试正反方向，ALL_DIRECTION=尝试所有方向
      goal_heading_mode: "DEFAULT"
      # 是否对搜索路径进行平滑后处理
      smooth_path: true
      smoother:
        # 执行额外的精细化平滑（递归平滑以改善宏观趋势）
        do_refinement: true
        # 平滑器的最大迭代次数
        max_iterations: 1000
        # 平滑终止的参数变化容差
        tolerance: 1.0e-10
        # 保留原始路径信息的权重
        w_data: 0.3
        # 平滑程度的权重
        w_smooth: 0.2

    GridBased:
      # 规划器插件类型（2D 全向 A*）
      plugin: "nav2_smac_planner/SmacPlanner2D"
      # 无法精确到达目标时的容差（m）
      tolerance: 0.3
      # 是否允许在未知空间中搜索路径
      allow_unknown: false
      # 最大搜索迭代次数，-1 表示不限制
      max_iterations: 1000000
      # 进入容差范围后继续尝试精确匹配的最大迭代次数
      max_on_approach_iterations: 1000
      # 规划器最大规划时间（s）
      max_planning_time: 2.0
      # 检查目标取消或规划超时的迭代间隔
      terminal_checking_interval: 5000
      # 代价乘数，越大越倾向于走低代价区域（0.0=忽略代价仅做二值搜索）
      cost_travel_multiplier: 2.0
      # 是否将路径终点朝向设为接近方向（false=使用请求的目标朝向）
      use_final_approach_orientation: false
      # 是否下采样代价图以降低分辨率进行搜索
      downsample_costmap: false
      # 下采样倍数（如 5cm 代价图 2 倍下采样 = 10cm 分辨率）
      downsampling_factor: 1
      # 是否对搜索路径进行平滑后处理
      smooth_path: true
      smoother:
        # 执行额外的精细化平滑（递归平滑以改善宏观趋势）
        do_refinement: true
        # 平滑器的最大迭代次数
        max_iterations: 1000
        # 平滑终止的参数变化容差
        tolerance: 1.0e-10
        # 保留原始路径信息的权重
        w_data: 0.3
        # 平滑程度的权重
        w_smooth: 0.2

    HybridBased:
      # 规划器插件类型（Hybrid-A*）
      plugin: "nav2_smac_planner/SmacPlannerHybrid"
      # 非直线运动的惩罚系数
      non_straight_penalty: 9.0
      # 对高代价区域的惩罚系数，使搜索避开障碍物
      cost_penalty: 2.0
      # 无法精确到达目标时的启发式距离容差
      tolerance: 0.5
      # 规划器最大规划时间（s）
      max_planning_time: 10.0
      # 是否允许在未知空间中搜索路径
      allow_unknown: false
      # 最大搜索迭代次数，-1 表示不限制
      max_iterations: 8000000
      # 进入容差范围后继续尝试精确匹配的最大迭代次数
      max_on_approach_iterations: 100000
      # 检查目标取消或规划超时的迭代间隔
      terminal_checking_interval: 5000
      # 车辆最小转弯半径（m）
      minimum_turning_radius: 0.05
      # 搜索用运动模型：DUBIN（仅前进）或 REEDS_SHEPP（可倒车）
      motion_model_for_search: "DUBIN"
      # 角度量化槽数，72=5度增量，48≈7.5度增量
      angle_quantization_bins: 48
      # 倒车搜索的惩罚系数（仅 REEDS_SHEPP 模型有效）
      reverse_penalty: 2.0
      # 切换方向（如左转→右转）的惩罚系数（0.0=保持可纳性）
      change_penalty: 0.0
      # 偏好后期转向的惩罚系数，节省搜索时间（0.0=完全可纳，1.0=最大偏好）
      retrospective_penalty: 0.015
      # 尝试解析展开的频率比例，值越大越频繁尝试直接用曲线到达目标
      analytic_expansion_ratio: 3.5
      # 解析展开的最大长度（m），防止从远处抄近路穿过高代价区域
      analytic_expansion_max_length: 3.0
      # 解析展开路径中允许的最大单点代价值，超过则认为无效（接近目标时除外）
      analytic_expansion_max_cost: 200.0
      # 在关键距离内是否覆盖最大代价限制（接近目标时允许高代价展开）
      analytic_expansion_max_cost_override: false
      # Dubin/Reeds-Sheep 距离窗口缓存大小（m）
      lookup_table_size: 20.0
      # 缓存障碍物距离启发式，加速同一目标的重规划（静态地图时效果显著）
      cache_obstacle_heuristic: true
      # 下采样障碍物启发式代价图以加速搜索（略微降低路径质量）
      downsample_obstacle_heuristic: true
      # 是否下采样代价图以降低分辨率进行搜索
      downsample_costmap: true
      # 下采样倍数（如 5cm 代价图 2 倍下采样 = 10cm 分辨率）
      downsampling_factor: 2
      # 是否对搜索路径进行平滑后处理
      smooth_path: true
      smoother:
        # 执行额外的精细化平滑（递归平滑以改善宏观趋势）
        do_refinement: true
        # 平滑器的最大迭代次数
        max_iterations: 1000
        # 平滑终止的参数变化容差
        tolerance: 1.0e-10
        # 保留原始路径信息的权重
        w_data: 0.3
        # 平滑程度的权重
        w_smooth: 0.2

    # qos_overrides:
    #   /tf:
    #     subscription:
    #       depth: 1
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "best_effort"
    #   /tf_static:
    #     subscription:
    #       depth: 1
    #       durability: "transient_local"
    #       history: "keep_last"
    #       reliability: "reliable"

# =============================================================================
# Local Costmap Configuration - 本地代价图
# =============================================================================
# Costmap 2D 包实现了基于 2D 网格的代价图用于环境表示，以及多种传感器处理插件（AI 输出、
# 深度传感器障碍物缓冲、语义信息等）。它在规划器和控制器服务器中用于创建碰撞检查空间
# 或需要绕行的高代价区域。
# 本地代价图（local costmap）使用滚动窗口（rolling_window），以机器人为中心动态移动。
# =============================================================================
local_costmap:
  local_costmap:
    ros__parameters:
      # 是否使用仿真时间
      use_sim_time: false

      # 代价图核心参数
      # 参考坐标系
      global_frame: odom
      # 机器人基坐标系
      robot_base_frame: base_link
      # 代价图更新频率（Hz）
      update_frequency: 10.0
      # 代价图发布到话题的频率（Hz），较高值提供更频繁的更新但增加带宽
      publish_frequency: 10.0
      # TF 变换容差（s）
      transform_tolerance: 0.5
      # 等待从 robot_base_frame 到 global_frame 的变换可用的时间（s），超时则中止配置阶段
      initial_transform_timeout: 60.0
      
      # 地图参数
      # 是否使用滚动窗口（代价图跟随机器人移动，保持以机器人为中心的局部视图）
      rolling_window: true
      # 代价图宽度（m）
      width: 12
      # 代价图高度（m）
      height: 12
      # 代价图中每个单元格（像素）的分辨率（m），越小精度越高但计算量更大
      resolution: 0.05
      # 代价图 X 原点相对于宽度的偏移（m）
      origin_x: -6.0
      # 代价图 Y 原点相对于高度的偏移（m）
      origin_y: -6.0
      # 用于可视化的地图高度，帮助避免 RViz 闪烁问题（如设为 -0.008）
      map_vis_z: 0.0

      # 足迹参数
      # 有序的足迹点集，以字符串形式传入，必须为闭合多边形。可通过 ~/footprint 话题动态调整
      footprint: "[[-0.35, -0.25], [-0.35, 0.25], [0.35, 0.25], [0.35, -0.25]]"
      # 足迹膨胀填充量（m）
      footprint_padding: 0.05
      # 若未提供足迹坐标，则使用此半径（m）。设置此参数时 isPathValid 使用圆形碰撞检查
      robot_radius: 0.35
      # 是否订阅 PolygonStamped 足迹消息（而非 Polygon），允许足迹包含时间戳和帧信息
      subscribe_to_stamped_footprint: false

      # 代价图行为参数
      # 是否每次更新发送完整代价图（而非仅增量更新）
      always_send_full_costmap: true
      # 是否追踪未知空间。false 将未知空间视为自由空间，true 视为未知空间
      track_unknown_space: true
      # 占位栅格地图是否应仅解释为 3 种值（自由、占用、未知），还是使用其存储的值
      trinary_costmap: true
      # 追踪未知空间时未知空间的代价值
      unknown_cost_value: 255
      # 占位栅格地图中被视为致命障碍物的最小代价值
      lethal_cost_threshold: 100
      # 代价图转换操作中表示 INSCRIBED_INFLATED_OBSTACLE 的占位栅格值
      inscribed_obstacle_cost_value: 99
      # 组合多个代价图层时是否使用最大代价。true 保留最高代价确保障碍物不被覆盖，false 新层可能覆盖之前的代价值
      use_maximum: false

      # 话题
      # 地图话题
      map_topic: "map"

      # 系统配置
      # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
      introspection_mode: "disabled"
      # 是否允许通过参数化值覆盖 QoS 配置
      allow_parameter_qos_overrides: true

      # 插件配置
      # "voxel_layer", "stvl_layer",  # 映射的插件名称列表，用于参数命名空间和名称
      plugins: ["traversability_layer_local","obstacle_layer_local", "inflation_layer_local"]
      
      # =====================================================
      # 可通行性层参数 - 基于点云高度差和坡度分析三维地形
      # =====================================================
      traversability_layer_local:
        # 插件类型
        plugin: "traversability_layer::TraversabilityLayer"
        # 是否启用
        enabled: true
        # 点云话题
        pointcloud_topic: /rkbot/lio/cloud_world
        # 机器人基准坐标系
        base_frame: base_link
        # 最大障碍物高度（m），高于此忽略
        max_obstacle_height: 1.0
        # 最小障碍物高度（m），低于此忽略
        min_obstacle_height: -1.0
        # 最大可通行坡度（°），超过则 lethal
        max_slope_traversable: 60.0
        # 开始产生坡度代价的坡度角（°）
        slope_cost_start: 40.0
        # 坡度代价缩放系数
        slope_cost_scale: 1.0
        # 障碍物比率阈值
        obstacle_ratio_threshold: 0.5
        # 障碍物命中阈值
        obstacle_hit_threshold: 1
        # 台阶高度阈值（m），超过则 lethal
        step_height_threshold: 0.4
        # 产生高度代价的最小高度（m）
        height_cost_start: 0.2
        # 高度代价缩放系数
        height_cost_scale: 0.1
        # 致命代价阈值
        lethal_cost_threshold: 254.0
        # 点云保留时间（s），0=仅用最新帧
        observation_persistence: 0.0
        # 点云缓冲队列长度
        cloud_buffer_size: 5
        # 是否发布坡度可视化点云
        publish_slope_map: true
        # 是否启用射线追踪清除
        enable_raycast_clear: false
        # 可通行性分析网格分辨率（m）
        cell_resolution: 0.1
        # OpenMP 线程数，0=系统默认
        num_threads: 4

      # =====================================================
      # 障碍物层参数
      # =====================================================
      # 此代价图层实现使用 2D 射线投射的插件，适用于 2D 激光雷达、深度或其他传感器。
      # 它内部包含一个 2D 代价图模型，通过以下参数管理规划空间。
      # =====================================================
      obstacle_layer_local:
        # 插件类型
        plugin: "nav2_costmap_2d::ObstacleLayer"
        # 是否启用
        enabled: true
        # 观测数据源名称列表
        observation_sources: scan_rear scan_front
        # 将数据添加到主代价图的方法：0=覆盖，1=取最大值（默认），2=取最大值但不覆盖未知信息
        combination_method: 1
        # 是否清除机器人足迹下的占用单元格
        footprint_clearing_enabled: true
        # 添加到占位栅格的最大高度（m）
        max_obstacle_height: 100.0
        # 添加到占位栅格的最小高度（m）
        min_obstacle_height: -100.0
        # tf2_ros::MessageFilter 的容差（s）
        tf_filter_tolerance: 0.05
        
        scan_rear:
          # 数据话题。相对话题相对于节点父命名空间
          topic: /rkbot/scan_rear
          # 传感器帧，若消息未提供则使用此帧。空字符串使用消息的 frame_id
          sensor_frame: ""
          # 输入数据类型：LaserScan 或 PointCloud2
          data_type: "LaserScan"
          # 在缓冲区中存储消息以添加到代价图的时长（s），之后移除
          observation_persistence: 0.0
          # 从传感器获取新数据的预期频率（Hz）
          expected_update_rate: 0.0
          # 激光扫描仪的无限返回值是否为有效测量（用于射线投射）
          inf_is_valid: true
          # 此数据源是否应在代价图中标记障碍物
          marking: true
          # 此数据源是否应在代价图中射线追踪清除障碍物
          clearing: true
          # 此数据源添加到占位栅格的最大高度（m）
          max_obstacle_height: 100.0
          # 此数据源添加到占位栅格的最小高度（m）
          min_obstacle_height: -100.0
          # 在代价图中标记障碍物的最大距离（m）
          obstacle_max_range: 10.0
          # 在代价图中标记障碍物的最小距离（m）
          obstacle_min_range: 0.0
          # 从代价图中射线追踪清除障碍物的最大距离（m）
          raytrace_max_range: 10.0
          # 从代价图中射线追踪清除障碍物的最小距离（m）
          raytrace_min_range: 0.0

        scan_front:
          # 数据话题
          topic: /rkbot/scan_front
          # 传感器帧
          sensor_frame: ""
          # 数据类型
          data_type: "LaserScan"
          # 消息缓冲区保留时长（s）
          observation_persistence: 0.0
          # 预期传感器更新频率（Hz）
          expected_update_rate: 0.0
          # 无限返回值是否有效
          inf_is_valid: true
          # 仅清除不标记（用于动态物体去除）
          marking: false
          # 是否清除障碍物（射线追踪）
          clearing: true
          # 最大障碍物高度（m）
          max_obstacle_height: 100.0
          # 最小障碍物高度（m）
          min_obstacle_height: -100.0
          # 0=不标记障碍物
          obstacle_max_range: 0.0
          # 障碍物检测最小范围（m）
          obstacle_min_range: 0.0
          # 射线追踪最大范围（m）
          raytrace_max_range: 10.0
          # 射线追踪最小范围（m）
          raytrace_min_range: 0.0
      
      # =====================================================
      # 膨胀层参数
      # =====================================================
      # 此图层在障碍物周围放置指数衰减函数，以增加穿越近碰撞区域的代价。
      # 它还在机器人完全内切半径范围内的障碍物周围放置致命代价——即使机器人是非圆形的，
      # 也可用于优化的一阶碰撞检查。
      # =====================================================
      inflation_layer_local:
        # 插件类型
        plugin: "nav2_costmap_2d::InflationLayer"
        # 是否启用
        enabled: true
        # 在致命障碍物周围膨胀代价图的半径（m）
        inflation_radius: 0.5
        # 膨胀半径上的指数衰减因子
        cost_scaling_factor: 10.0
        # 是否将未知单元格如同致命单元格一样膨胀
        inflate_unknown: false
        # 是否在未知单元格周围膨胀
        inflate_around_unknown: false
        # 启用 OpenMP 时用于膨胀计算的线程数，-1 为自动检测（使用一半可用 CPU 核心），正整数指定显式线程数
        num_threads: -1
      

      # STVL (Spatio-Temporal Voxel Layer) - 3D点云障碍物层
      # stvl_layer:
      #   plugin: "spatio_temporal_voxel_layer/SpatioTemporalVoxelLayer"
      #   enabled: true
      #   # 体素衰减时间（秒）
      #   voxel_decay: 5.0  
      #   # 衰减模型：0=线性，1=指数  
      #   decay_model: 0  
      #   # 体素大小（米）
      #   voxel_size: 0.05  
      #   track_unknown_space: true
      #   observation_persistence: 0.0
      #   max_obstacle_height: 1.0
      #   min_obstacle_height: -0.2
      #   publish_voxel_map: true
      #   observation_sources: pointcloud
      #   pointcloud:
      #     topic: /rkbot/lio/cloud_world  # 点云话题
      #     max_obstacle_height: 1.0
      #     min_obstacle_height: -0.2
      #     obstacle_max_range: 10.0
      #     obstacle_min_range: 0.1
      #     raytrace_max_range: 10.0
      #     raytrace_min_range: 0.1
      #     clearing: true
      #     marking: true
      #     data_type: "PointCloud2"
      #     sensor_frame: "rslidar_head"  # 点云传感器坐标系
      #     observation_persistence: 0.0
      #     inf_is_valid: true
      #     filter: "voxel"  # 点云滤波器
      #     voxel_min_points: 2  # 体素最小点数
      #     clear_after_reading: false
      #     max_update_rate: 10.0


      # # 体素层参数
      # voxel_layer:
      #   plugin: "nav2_costmap_2d::VoxelLayer"
      #   enabled: true
      #   publish_voxel_map: true
      #   origin_z: 0.0  # 负值以容纳传感器原点的负值z坐标
      #   z_resolution: 0.05
      #   z_voxels: 16    # 增加体素数量以保持足够的垂直覆盖范围
      #   max_obstacle_height: 2.0
      #   min_obstacle_height: -0.5
      #   # mark_threshold: 0.5
      #   observation_sources: scan
      #   scan:
      #     topic: /scan
      #     max_obstacle_height: 1.8
      #     min_obstacle_height: -0.5
      #     clearing: true
      #     marking: false
      #     data_type: "LaserScan"
      #     raytrace_max_range: 3.0
      #     raytrace_min_range: 0.3
      #     obstacle_max_range: 2.5
      #     obstacle_min_range: 0.3

      # qos_overrides:
      #   /tf:
      #     subscription:
      #       depth: 1
      #       durability: "volatile"
      #       history: "keep_last"
      #       reliability: "best_effort"
      #   /tf_static:
      #     subscription:
      #       depth: 1
      #       durability: "transient_local"
      #       history: "keep_last"
      #       reliability: "reliable"

# =============================================================================
# Global Costmap Configuration - 全局代价图
# =============================================================================
# 全局代价图（global costmap）用于在整个环境中进行长期规划。它通常使用静态地图，
# 不随机器人移动而滚动。它提供全局规划器用于生成从起点到目标路径的完整环境表示。
# =============================================================================
global_costmap:
  global_costmap:
    ros__parameters:
      # 是否使用仿真时间
      use_sim_time: false

      # 代价图核心参数
      # 参考坐标系
      global_frame: map
      # 机器人基坐标系
      robot_base_frame: base_link
      # 代价图更新频率（Hz），全局图通常较低
      update_frequency: 0.1
      # 代价图发布到话题的频率（Hz）
      publish_frequency: 0.1
      # TF 变换容差（s）
      transform_tolerance: 0.5
      # 等待从 robot_base_frame 到 global_frame 的变换可用的时间（s），超时则中止配置阶段
      initial_transform_timeout: 60.0
      
      # 地图参数
      # 是否使用滚动窗口。全局代价图通常为 false，使用静态地图的完整范围
      rolling_window: false
      # 代价图宽度（m），仅 rolling_window=true 时有效
      width: 10
      # 代价图高度（m），仅 rolling_window=true 时有效
      height: 10
      # 代价图中每个单元格（像素）的分辨率（m）
      resolution: 0.05
      # 代价图 X 原点相对于宽度的偏移（m）
      origin_x: 0.0
      # 代价图 Y 原点相对于高度的偏移（m）
      origin_y: 0.0
      # 用于可视化的地图高度
      map_vis_z: 0.0

      # 足迹参数
      # 有序的足迹点集，必须为闭合多边形
      footprint: "[[-0.35, -0.25], [-0.35, 0.25], [0.35, 0.25], [0.35, -0.25]]"
      # 足迹膨胀填充量（m）
      footprint_padding: 0.05
      # 若未提供足迹坐标，则使用此半径（m）
      robot_radius: 0.35
      # 是否订阅 PolygonStamped 足迹消息
      subscribe_to_stamped_footprint: false

      # 代价图行为参数
      # 是否每次更新发送完整代价图。全局代价图通常为 false，发送增量更新
      always_send_full_costmap: false
      # 是否追踪未知空间
      track_unknown_space: false
      # 占位栅格地图是否应仅解释为 3 种值（自由、占用、未知）
      trinary_costmap: true
      # 追踪未知空间时未知空间的代价值
      unknown_cost_value: 255
      # 占位栅格地图中被视为致命障碍物的最小代价值
      lethal_cost_threshold: 200
      # 代价图转换操作中表示 INSCRIBED_INFLATED_OBSTACLE 的占位栅格值
      inscribed_obstacle_cost_value: 99
      # 组合多个代价图层时是否使用最大代价
      use_maximum: false

      # 话题
      # 静态地图话题
      map_topic: "map"

      # 系统配置
      # 服务和动作的内省模式
      introspection_mode: "disabled"
      # 是否允许通过参数化值覆盖 QoS 配置
      allow_parameter_qos_overrides: true
    
      # 插件配置
      # 映射的插件名称列表
      plugins: ["static_layer", "obstacle_layer", "inflation_layer"]
      
      # =====================================================
      # 静态层参数
      # =====================================================
      # 静态图层从 SLAM 生成的静态地图中加载信息，提供环境的先验知识。
      # 它存在于全局代价图中，为规划器提供全局环境上下文。
      # =====================================================
      static_layer:
        # 插件类型
        plugin: "nav2_costmap_2d::StaticLayer"
        # 是否启用
        enabled: true
        # 静态地图话题
        map_topic: "map"
        # 是否订阅地图更新。如果仅需加载一次直接地图，可设为 false
        subscribe_to_updates: true
        # 使用 TRANSIENT_LOCAL 持久化进行地图订阅，使新订阅者能接收之前发布的地图
        map_subscribe_transient_local: true

      # =====================================================
      # 障碍物层参数
      # =====================================================
      obstacle_layer:
        # 插件类型
        plugin: "nav2_costmap_2d::ObstacleLayer"
        # 全局代价图默认禁用障碍物层，由静态地图提供全局信息
        enabled: false
        # 观测数据源名称列表
        observation_sources: scan
        # 将数据添加到主代价图的方法：0=覆盖，1=取最大值
        combination_method: 1
        # 是否清除机器人足迹下的占用单元格
        footprint_clearing_enabled: true
        # 添加到占位栅格的最大高度（m）
        max_obstacle_height: 2.0
        # 添加到占位栅格的最小高度（m）
        min_obstacle_height: -0.5
        # tf2_ros::MessageFilter 的容差（s）
        tf_filter_tolerance: 0.05

        scan:
          # 数据话题
          topic: /rkbot/scan
          # 传感器帧
          sensor_frame: ""
          # 数据类型
          data_type: "LaserScan"
          # 消息缓冲区保留时长（s）
          observation_persistence: 0.0
          # 预期传感器更新频率（Hz）
          expected_update_rate: 0.0
          # 无限返回值是否有效
          inf_is_valid: true
          # 是否标记障碍物
          marking: true
          # 是否清除障碍物（射线追踪）
          clearing: true
          # 此数据源的最大障碍物高度（m）
          max_obstacle_height: 1.8
          # 此数据源的最小障碍物高度（m）
          min_obstacle_height: -0.1
          # 标记障碍物的最大距离（m）
          obstacle_max_range: 10.0
          # 标记障碍物的最小距离（m）
          obstacle_min_range: 0.0
          # 射线追踪清除的最大距离（m）
          raytrace_max_range: 10.0
          # 射线追踪清除的最小距离（m）
          raytrace_min_range: 0.0
      
      # =====================================================
      # 膨胀层参数
      # =====================================================
      # 在障碍物周围放置指数衰减函数，增加穿越近碰撞区域的代价。
      # 全局代价图的膨胀半径通常较大，以提供更保守的全局路径规划。
      # =====================================================
      inflation_layer:
        # 插件类型
        plugin: "nav2_costmap_2d::InflationLayer"
        # 是否启用
        enabled: true
        # 在致命障碍物周围膨胀代价图的半径（m）
        inflation_radius: 10.0
        # 膨胀半径上的指数衰减因子
        cost_scaling_factor: 3.0
        # 是否将未知单元格如同致命单元格一样膨胀
        inflate_unknown: true
        # 是否在未知单元格周围膨胀
        inflate_around_unknown: true
        # 用于膨胀计算的线程数，-1 为自动检测
        num_threads: -1

# =============================================================================
# Lifecycle Manager Configuration - 生命周期管理器
# =============================================================================
# Lifecycle Manager 是一个基于 ROS 2 生命周期节点的节点管理器。它负责监督一组生命周期
# 节点，确保它们按正确顺序启动和关闭。它通过 bond 心跳机制监控节点状态，并在节点崩溃
# 或无响应时自动重启。
# =============================================================================
lifecycle_manager:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false
    # 是否自动启动所有生命周期节点
    autostart: true
    # 要管理的生命周期节点名称列表
    node_names: ['planner_server', 'controller_server', 'bt_navigator', 'waypoint_follower', 'velocity_smoother']
    # 心跳超时时间（ms），在此时间内未收到心跳则视为节点崩溃
    bond_timeout_ms: 10000
    # 节点崩溃后允许的最大延迟时间（s），超过此时间则不再尝试重启
    bond_respawn_max_duration: 10.0
    # 是否尝试重新连接并重启崩溃的节点
    attempt_respawn_reconnection: true

# # 单独的定位生命周期管理器配置
# lifecycle_manager_localization:
#   ros__parameters:
#     use_sim_time: false
#     autostart: true
#     node_names: ['map_server', 'amcl']
#     bond_timeout_ms: 10000

# =============================================================================
# AMCL Configuration - 自适应蒙特卡洛定位
# =============================================================================
# AMCL 实现了一个服务器，用于接收静态地图并通过自适应蒙特卡洛定位器（Adaptive Monte-Carlo 
# Localizer）在已知地图中对机器人进行定位。
# =============================================================================
amcl:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false

    # 坐标系配置
    # 定位系统发布的坐标帧名称
    global_frame_id: map
    # 用于里程计的坐标帧
    odom_frame_id: odom
    # 机器人基座坐标帧
    base_frame_id: base_link

    # 话题配置
    # 要订阅的激光扫描话题
    scan_topic: /rkbot/scan
    # 要订阅的地图话题
    map_topic: "map"
    # 里程计话题
    odom_topic: /rkbot/lio/odom

    # 粒子滤波器参数
    # 允许的最小粒子数
    min_particles: 800
    # 允许的最大粒子数
    max_particles: 4000
    # 粒子滤波器种群误差
    pf_err: 0.05
    # 粒子滤波器种群密度，0.99 对应 99% 分位数
    pf_z: 0.99
    # 粒子滤波器随机数种子，>=0 使用给定值（可复现），<0 使用时间种子（默认）
    random_seed: -1
    # 重采样前所需的滤波器更新次数
    resample_interval: 3

    # 更新阈值 - 执行滤波器更新前需要的最小平移/旋转运动量
    # 执行滤波器更新前所需的最小平移运动量（m）
    update_min_d: 0.05
    # 执行滤波器更新前所需的最小旋转运动量（rad）
    update_min_a: 0.05

    # 恢复参数 - 用于决定何时通过添加随机位姿进行恢复的指数衰减率
    # 慢速平均权重滤波器的指数衰减率，用于决定何时通过添加随机位姿恢复。合理值约为 0.001
    recovery_alpha_slow: 0.0
    # 快速平均权重滤波器的指数衰减率，用于决定何时通过添加随机位姿恢复。合理值约为 0.1
    recovery_alpha_fast: 0.0

    # 里程计运动模型噪声参数 - 里程计旋转/平移估计中的预期过程噪声
    # 里程计旋转估计中由旋转引起的预期过程噪声
    alpha1: 0.01
    # 里程计旋转估计中由平移引起的预期过程噪声
    alpha2: 0.01
    # 里程计平移估计中由平移引起的预期过程噪声
    alpha3: 0.02
    # 里程计平移估计中由旋转引起的预期过程噪声
    alpha4: 0.02
    # 仅 Omni 模型：平移噪声
    alpha5: 0.03

    # 机器人运动模型类型 - 插件类的完全限定类型
    # 全向运动模型，可选 nav2_amcl::DifferentialMotionModel
    robot_model_type: "nav2_amcl::OmniMotionModel"

    # 初始位姿配置
    # 使 AMCL 从 initial_pose 参数设置初始位姿，而非等待 initial_pose 消息
    set_initial_pose: true
    # 要求 AMCL 在重置时必须通过话题或 initial_pose 参数提供初始位姿。否则 AMCL 默认使用上次已知位姿初始化
    always_reset_initial_pose: false
    # 是否仅接受第一张地图。设为 false 允许 AMCL 在 map_topic 上多次接收地图（使用 map_server 的 LoadMap 服务时特别有用）
    first_map_only: false
    # 存储最后估计位姿和协方差到参数服务器的最大频率（Hz），-1.0 禁用。后续运行将使用此保存的位姿初始化滤波器
    save_pose_rate: 0.3

    # 激光雷达配置
    # 要考虑的最小扫描距离，-1.0 使用激光雷达报告的最小距离
    laser_min_range: 0.1
    # 要考虑的最大扫描距离，-1.0 使用激光雷达报告的最大距离
    laser_max_range: 100.0
    # 每次扫描中用于更新滤波器的均匀分布光束数量
    max_beams: 180

    # TF 相关
    # TF 变换容差（s）
    transform_tolerance: 0.5
    # 设为 false 可阻止 AMCL 发布 global_frame 与 odom_frame 之间的变换
    tf_broadcast: true

    # 系统配置
    # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true

    # =============================================================================
    # BEAM MODEL 参数 - 适用于结构化环境
    # Beam 模型使用完整的 4 个混合权重（z_hit + z_max + z_short + z_rand = 1）
    # 取消注释使用 Beam 模型，注释掉 Likelihood 模型参数
    # =============================================================================
    # laser_model_type: "beam"                                                              # 使用哪种模型：beam、likelihood_field 或 likelihood_field_prob
    # lambda_short: 0.1                                                                     # 模型 z_short 部分的指数衰减参数
    # sigma_hit: 0.08                                                                       # 模型 z_hit 部分使用的高斯模型标准差
    # z_hit: 0.70                                                                           # z_hit 部分的混合权重（命中），所有 z 权重之和必须为 1
    # z_max: 0.15                                                                           # z_max 部分的混合权重（最大距离），所有 z 权重之和必须为 1
    # z_short: 0.05                                                                         # z_short 部分的混合权重（短距离），所有 z 权重之和必须为 1
    # z_rand: 0.20                                                                          # z_rand 部分的混合权重（随机），所有 z 权重之和必须为 1

    # =============================================================================
    # LIKELIHOOD FIELD MODEL 参数 - 适用于非结构化环境
    # Likelihood 模型仅使用 z_hit 和 z_rand（z_hit + z_rand = 1）
    # =============================================================================
    # 激光模型类型：beam / likelihood_field / likelihood_field_prob（同 likelihood_field 但支持 beamskip）
    laser_model_type: "likelihood_field_prob"

    # 传感器模型参数
    # 模型 z_hit 部分使用的高斯模型标准差
    sigma_hit: 0.08
    # 模型 z_short 部分的指数衰减参数
    lambda_short: 0.1
    # z_hit 部分的混合权重（命中）
    z_hit: 0.60
    # z_rand 部分的混合权重（随机测量）
    z_rand: 0.40
    # 地图上障碍物膨胀的最大距离（m），用于 likelihood_field 模型
    laser_likelihood_max_dist: 60.0

    # Beam 跳过参数 - 在 Likelihood 场模型中跳过大多数粒子不同意的光束
    # 是否在 Likelihood 场模型中执行光束跳过
    do_beamskip: true
    # 忽略大多数粒子不同意的光束，考虑跳过的最大距离（m）
    beam_skip_distance: 0.4
    # 跳过所需的光束比例阈值
    beam_skip_threshold: 0.3
    # beam_skip_error_threshold: 0.9                                                          # 光束未匹配地图的比例超过此值后强制进行完整更新（由于收敛不良）

# =============================================================================
# BT Navigator Configuration - 行为树导航器
# =============================================================================
# BT Navigator 模块实现了 NavigateToPose、NavigateThroughPoses 等任务接口。它是一个基于
# 行为树（Behavior Tree）的导航实现，旨在提供导航任务的灵活性，并允许轻松指定复杂的机器人
# 行为（包括恢复行为）。行为树 XML 文件可使用 Groot 进行可视化和修改。
# =============================================================================
bt_navigator:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false

    # 坐标系
    # 参考坐标系
    global_frame: map
    # 机器人基坐标系
    robot_base_frame: base_link

    # 话题
    # 里程计发布话题
    odom_topic: "/rkbot/lio/odom"
    # TF 变换容差（s）
    transform_tolerance: 0.5

    # 行为树主循环
    # BT 每次迭代执行的持续时间（ms）
    bt_loop_duration: 100
    # BT 动作节点等待动作服务器确认的默认超时时间（ms），可通过输入端口 "server_timeout" 覆盖
    default_server_timeout: 200
    # BT 动作节点在节点停止时取消请求的默认超时时间（ms），可通过输入端口 "cancel_timeout" 覆盖
    default_cancel_timeout: 50
    # 动作或服务 BT 节点在 BT 初始化时等待服务或动作服务器确认的默认超时时间（ms），可通过输入端口 "wait_for_service_timeout" 覆盖
    wait_for_service_timeout: 100

    # 行为树 XML 配置
    # NavigateToPose 的默认行为树 XML 文件路径
    default_nav_to_pose_bt_xml: "/home/ztl/dog_slam/LIO-SAM_MID360_ROS2_PKG/ros2/src/nav2_dog_slam/config/navigate_to_pose_w_replanning_and_recovery.xml"
    # default_nav_through_poses_bt_xml: "/opt/ros/humble/share/nav2_bt_navigator/behavior_trees/navigate_to_pose_w_replanning_and_recovery.xml"  # NavigateThroughPoses 的默认行为树 XML 文件路径
    # 是否始终加载请求的行为树 XML，无论当前活跃 XML 名称如何
    always_reload_bt_xml: false

    # BT 日志与搜索目录
    # 是否将行为树中的空闲（无状态变化）转换记录到 /behavior_tree_log 话题。false 时仅记录状态变化，减少噪音
    bt_log_idle_transitions: true
    # 托管行为树 XML 文件的目录列表，用于注册所有行为树和子树
    bt_search_directories:
      - $(find-pkg-share nav2_bt_navigator)/behavior_trees

    # 导航器抢占
    # 控制新导航目标是否可以抢占当前活跃导航器。false=新目标被拒绝，true=新目标通知活跃导航器停止后接管
    allow_navigator_preemption: false
    # 等待当前活跃导航器停止的最大时间（ms），仅 allow_navigator_preemption=true 时有效
    navigator_preemption_timeout: 500

    # 导航器插件列表
    # 实现 nav2_core::BehaviorTreeNavigator 接口的导航器类型插件列表
    navigators: ['navigate_to_pose', 'navigate_through_poses']

    # NavigateToPose 导航器参数
    navigate_to_pose:
      # 导航器插件类型
      plugin: "nav2_bt_navigator::NavigateToPoseNavigator"
      # 是否为此导航器启用 Groot2 监控
      enable_groot_monitoring: false
      # Groot2 服务器端口（Groot2 中只需指定服务器端口，发布端口始终为 server_port+1）
      groot_server_port: 1667
      # 搜索算法沿路径向前查找最近点的距离（m）
      search_window: 2.0

    # NavigateThroughPoses 导航器参数
    navigate_through_poses:
      # 导航器插件类型
      plugin: "nav2_bt_navigator::NavigateThroughPosesNavigator"
      # 是否为此导航器启用 Groot2 监控
      enable_groot_monitoring: false
      # Groot2 服务器端口
      groot_server_port: 1669
      # 搜索算法沿路径向前查找最近点的距离（m）
      search_window: 2.0

    # 黑板书变量 ID
    # 用于向行为树提供目标的黑板变量，应与 BT XML 文件端口匹配
    goal_blackboard_id: "goal"
    # 用于向行为树提供目标列表的黑板变量
    goals_blackboard_id: "goals"
    # 从行为树获取路径反馈的黑板变量
    path_blackboard_id: "path"
    # 从行为树获取航点状态反馈/结果的黑板变量
    waypoint_statuses_blackboard_id: "waypoint_statuses"

    # 速度平滑与错误码
    # 机器人速度平滑的持续时间（s）
    filter_duration: 0.3
    # Kilted 及更新版本：错误码名称前缀列表，将被追加 '_error_code' 和 '_error_msg' 后缀，用于终止导航器错误处理
    error_code_name_prefixes:
      - assisted_teleop
      - backup
      - compute_path
      - dock_robot
      - drive_on_heading
      - follow_path
      - nav_thru_poses
      - nav_to_pose
      - spin
      - route
      - undock_robot
      - wait

    # 系统配置
    # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true
    
    # 插件库
    # BT 节点插件共享库列表。所有 Nav2 BT 库已自动包含，此处仅需添加自定义插件
    plugin_lib_names:
      - nav2_compute_path_to_pose_action_bt_node
      - nav2_compute_path_through_poses_action_bt_node
      - nav2_smooth_path_action_bt_node
      - nav2_follow_path_action_bt_node
      - nav2_spin_action_bt_node
      - nav2_wait_action_bt_node
      - nav2_assisted_teleop_action_bt_node
      - nav2_back_up_action_bt_node
      - nav2_drive_on_heading_bt_node
      - nav2_clear_costmap_service_bt_node
      - nav2_is_stuck_condition_bt_node
      - nav2_goal_reached_condition_bt_node
      - nav2_goal_updated_condition_bt_node
      - nav2_globally_updated_goal_condition_bt_node
      - nav2_is_path_valid_condition_bt_node
      - nav2_initial_pose_received_condition_bt_node
      - nav2_reinitialize_global_localization_service_bt_node
      - nav2_rate_controller_bt_node
      - nav2_distance_controller_bt_node
      - nav2_speed_controller_bt_node
      - nav2_truncate_path_action_bt_node
      - nav2_truncate_path_local_action_bt_node
      - nav2_goal_updater_node_bt_node
      - nav2_recovery_node_bt_node
      - nav2_pipeline_sequence_bt_node
      - nav2_round_robin_node_bt_node
      - nav2_transform_available_condition_bt_node
      - nav2_time_expired_condition_bt_node
      - nav2_path_expiring_timer_condition
      - nav2_distance_traveled_condition_bt_node
      - nav2_single_trigger_bt_node
      - nav2_goal_updated_controller_bt_node
      - nav2_is_battery_low_condition_bt_node
      - nav2_navigate_through_poses_action_bt_node
      - nav2_navigate_to_pose_action_bt_node
      - nav2_remove_passed_goals_action_bt_node
      - nav2_planner_selector_bt_node
      - nav2_controller_selector_bt_node
      - nav2_goal_checker_selector_bt_node
      - nav2_controller_cancel_bt_node
      - nav2_path_longer_on_approach_bt_node
      - nav2_wait_cancel_bt_node
      - nav2_spin_cancel_bt_node
      - nav2_back_up_cancel_bt_node
      - nav2_assisted_teleop_cancel_bt_node
      - nav2_drive_on_heading_cancel_bt_node
      - nav2_is_battery_charging_condition_bt_node
      - nav2_progress_checker_selector_bt_node




# =============================================================================
# Map Server Configuration - 地图服务器
# =============================================================================
# Map Server 负责加载和提供静态地图（OccupancyGrid）。它从 YAML 文件中读取地图配置，
# 加载对应的地图图像文件，并将其发布为 ROS 2 话题供其他节点使用。
# =============================================================================
map_server:
  ros__parameters:
    # 地图坐标系
    frame_id: map
    # 是否使用仿真时间
    use_sim_time: false
    # 要加载的地图 YAML 文件路径，包含地图图像路径、分辨率、原点等信息
    yaml_filename: /home/ztl/slam_data/grid_map/map.yaml

# =============================================================================
# Smoother Server Configuration - 路径平滑服务器
# =============================================================================
# Smoother Server 用于对规划器生成的路径进行平滑处理。它接收路径并应用优化算法，
# 以消除路径中的急转弯、提高路径的平滑度和可执行性。
# =============================================================================
smoother_server:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false
    # 代价图话题，用于平滑时的碰撞检查
    costmap_topic: "local_costmap/costmap_raw"
    # 足迹话题，用于平滑时的碰撞检查
    footprint_topic: "local_costmap/published_footprint"
    # 全局参考坐标系
    global_frame: "odom"
    # 机器人基坐标系
    robot_base_frame: "base_link"
    # TF 变换容差（s）
    transform_tolerance: 0.5
    # 平滑器插件名称列表
    smoother_plugins: ["simple_smoother"]
    
    # 系统配置
    # 服务和动作的内省模式
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true
    
    # =====================================================
    # Simple Smoother 参数
    # =====================================================
    # 简单路径平滑器使用梯度下降法对路径点进行平滑，同时保持与原始路径的接近度。
    # =====================================================
    simple_smoother:
      # 插件类型
      plugin: "nav2_smoother::SimpleSmoother"
      # 优化收敛的参数变化容差
      tolerance: 1.0e-10
      # 最大迭代次数
      max_its: 2
      # 是否执行额外的精细化平滑（递归平滑以改善宏观趋势）
      do_refinement: false
      # 保留原始路径信息的权重，值越大越接近原始路径
      w_data: 0.3
      # 平滑程度的权重，值越大路径越平滑
      w_smooth: 0.2



# =============================================================================
# Behavior Server Configuration - 行为服务器
# =============================================================================
# Behavior Server 实现了处理各种行为请求的服务器（如恢复行为和停靠），并托管向量化的 C++ 
# 行为插件实现。它也允许为每个自定义行为实现独立的行为服务器，但该服务器允许多个行为
# 共享资源（如代价图和 TF 缓冲区），从而降低新增行为的增量成本。
# 注意：wait 恢复行为没有参数，等待时长通过动作请求给出。
# =============================================================================
behavior_server:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false
    
    # 行为插件列表 - 也匹配动作服务器名称
    # 要使用的插件名称列表
    behavior_plugins: ["spin", "backup", "drive_on_heading", "wait"]

    # 代价图与足迹话题
    # 本地代价图原始代价图话题，用于碰撞检查
    local_costmap_topic: "local_costmap/costmap_raw"
    # 本地代价图帧中的足迹话题
    local_footprint_topic: "local_costmap/published_footprint"
    # 全局代价图原始代价图话题，用于碰撞检查
    global_costmap_topic: "global_costmap/costmap_raw"
    # 全局代价图帧中的足迹话题
    global_footprint_topic: "global_costmap/published_footprint"

    # 坐标系
    # 本地参考坐标系
    local_frame: "odom"
    # 全局参考坐标系
    global_frame: "map"
    # 机器人基坐标系
    robot_base_frame: "base_link"

    # 运行参数
    # 行为插件运行频率（Hz）
    cycle_frequency: 10.0
    # TF 变换容差（s）
    transform_tolerance: 0.5
    # 碰撞检测前向模拟时间（s）
    simulate_ahead_time: 0.0

    # 系统配置
    # 服务和动作的内省模式，可选 "disabled"、"metadata"、"contents"
    introspection_mode: "disabled"
    # 生命周期节点 bond 机制的发布周期（/bond 话题），<=0.0 禁用
    bond_heartbeat_period: 0.25
    # 是否允许通过参数化值覆盖 QoS 配置
    allow_parameter_qos_overrides: true

    # 速度命令类型（所有行为共用）
    # 是否使用 geometry_msgs::msg::TwistStamped（true）或 Twist（false）。Kilted 及更新版本默认 true，Jazzy 及更旧版本默认 false
    enable_stamped_cmd_vel: true
    
    # =====================================================
    # Spin 旋转行为参数
    # =====================================================
    # 旋转距离通过动作请求给出
    spin:
      # 旋转行为插件
      plugin: "nav2_behaviors/Spin"
      # 碰撞检测前向模拟时间（s）
      simulate_ahead_time: 0.0
      # 最大旋转速度（rad/s）
      max_rotational_vel: 1.0
      # 最小旋转速度（rad/s）
      min_rotational_vel: 0.4
      # 最大旋转加速度（rad/s²）
      rotational_acc_lim: 3.2

    # =====================================================
    # BackUp 后退行为参数
    # =====================================================
    # 后退距离、速度和 time_allowance 通过动作请求给出
    backup:
      # 后退行为插件
      plugin: "nav2_behaviors/BackUp"
      # 碰撞检测前向模拟时间（s）
      simulate_ahead_time: 0.0

    # BackUp 参数（带前缀放在顶层，不在 backup 命名空间内）
    # 后退最大加速度限制（m/s²），限制后退时速度增加的速率
    backup.acceleration_limit: 1.5
    # 后退最大减速度限制（m/s²），负值，限制后退时速度降低的速率
    backup.deceleration_limit: -2.0
    # 后退最小移动速度（m/s），机器人行为的死区速度，正值
    backup.minimum_speed: 0.15

    # =====================================================
    # DriveOnHeading 方向驱动行为参数
    # =====================================================
    # 方向驱动距离、速度和 time_allowance 通过动作请求给出
    drive_on_heading:
      # 方向驱动行为插件
      plugin: "nav2_behaviors/DriveOnHeading"
      # 碰撞检测前向模拟时间（s）
      simulate_ahead_time: 0.0

    # DriveOnHeading 参数（带前缀放在顶层）
    # 方向驱动最大加速度限制（m/s²）
    drive_on_heading.acceleration_limit: 2.5
    # 方向驱动最大减速度限制（m/s²），负值
    drive_on_heading.deceleration_limit: -2.5
    # 方向驱动最小移动速度（m/s），机器人行为的死区速度，正值
    drive_on_heading.minimum_speed: 0.10
      
    # =====================================================
    # Wait 等待行为
    # =====================================================
    wait:
      # 等待行为插件（无参数，等待时长在动作请求中给出）
      plugin: "nav2_behaviors/Wait"



# =============================================================================
# Waypoint Follower Configuration - 航点跟随器
# =============================================================================
# Waypoint Follower 实现了 NavigateThroughPoses 接口，用于按顺序导航到一系列航点位置。
# 它支持在每个航点执行自定义任务（如等待），然后继续前往下一个航点。
# =============================================================================
waypoint_follower:
  ros__parameters:
    # 是否使用仿真时间
    use_sim_time: false
    # 主循环运行频率（Hz）
    loop_rate: 20
    # 航点失败时是否停止后续所有航点执行。false 时即使某个航点失败仍继续执行下一个
    stop_on_failure: false
    # 航点任务执行器插件名称，用于在每个航点执行自定义任务
    waypoint_task_executor_plugin: "wait_at_waypoint"
    
    wait_at_waypoint:
      # 插件类型
      plugin: "nav2_waypoint_follower::WaitAtWaypoint"
      # 是否启用航点等待行为
      enabled: false
      # 到达每个航点后的暂停时长（ms）
      waypoint_pause_duration: 200
      
    # qos_overrides:
    #   /tf:
    #     subscription:
    #       depth: 1
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "best_effort"
    #   /tf_static:
    #     subscription:
    #       depth: 1
    #       durability: "transient_local"
    #       history: "keep_last"
    #       reliability: "reliable"

































slam_toolbox_node:
  ros__parameters:
    # 基本设置
    use_sim_time: false

    # 模式 - "mapping" 或 "localization" 模式，用于 Ceres 问题创建的性能优化
    #     工作原理与使用场景
    # LifeLong Mapping模式详解
    # 这个模式非常适合需要长期在动态环境中工作的机器人。它通过多会话（multi-session） 的管理方式，允许机器人不断地将运行过程中感知到的新环境变化（如新增的障碍物、改变的布局）整合到现有地图中。同时，它也会利用诸如Chow-Liu树等算法对位姿图进行稀疏化，以控制计算和存储成本，确保系统能够长期稳定运行。简单来说，它让地图"活"起来，伴随机器人的一生共同演进。
    # Localization模式详解
    # 一旦你拥有了一张高质量的地图，并且环境相对稳定，就可以切换到Localization模式。在此模式下，slam_toolbox的核心任务不再是构建地图，而是像一个更强大的自适应蒙特卡洛定位（AMCL） 一样，专注于解决"我在哪里"的问题。它通过匹配当前的传感器观测和已知地图，来提供精确的位姿，并修正里程计累积的漂移。
    mode: "mapping"  

    # 调试 / 可视化
    # 发布频率与变换发布
    # 禁止 slam_toolbox 输出/更新 2D occupancy map（避免覆盖 nav2 的 /map）
    # 将 map_update_interval 设为 0 将停止发布 OccupancyGrid
    map_update_interval: 5.0
    publish_occupancy_map: true

    # 地图文件 - 启动时加载的位姿图文件名（可由 launch 时覆盖 map_file_name）
    # map_file_name: '/home/ztl/slam_data/posegraph/my_map'

    # 启动时用于定位（与 AMCL 的 /initialpose 等价的参数）
    # 格式: [x, y, yaw] (单位: 米, 弧度)
    # 值示例: 将初始位姿设为 x=33.5, y=3.5, yaw=1.57
    # map_start_pose: [1.5, 1.5, 0.57]

    # 如果想以 dock（第一节点）作为启动位置，可以启用下一项
    map_start_at_dock: false

    # 坐标系
    # 里程计坐标系
    odom_frame: odom
    # 地图坐标系
    map_frame: map
    # 基座坐标系
    base_frame: base_link

    # 激光与里程计话题
    # 扫描话题 - 绝对路径，即 /scan 而不是 scan
    scan_topic: /rkbot/scan
    # 里程计话题
    odom_topic: /rkbot/lio/odom

    # 保持 transform publish（map->odom 发布通常需要）
    # 地图到里程计变换的发布周期，0 表示不发布变换
    transform_publish_period: 0.0

    # 传感器范围与匹配参数（可按需调优）
    # 最大激光范围 - 用于 2D 占用地图栅格化的最大激光范围
    max_laser_range: 100.0
    # 最小激光范围 - 用于 2D 占用地图栅格化的最小激光范围
    min_laser_range: 0.5

    # 使能局部scan-matching用于相对定位增强 - 必须启用以支持重定位
    use_scan_matching: false

    # 不启用内置的 map saver 服务以避免意外写盘或覆盖
    # 实例化地图保存服务并自订阅地图话题
    use_map_saver: false

    # =============================================================================
    # 新增重要参数配置 - 根据 ros2 param list 添加
    # =============================================================================
    
    # 角度方差惩罚 - 当匹配扫描与里程计位姿不同时应用的惩罚，用于重定位时惩罚与里程计不一致的位姿
    angle_variance_penalty: 1.0
    
    # 距离方差惩罚 - 当匹配扫描与里程计位姿不同时应用的惩罚，用于重定位时惩罚与里程计不一致的位姿
    distance_variance_penalty: 1.0
    
    # 最小角度惩罚 - 确保角度惩罚不会过大的最小惩罚值，防止重定位时角度变化过大
    minimum_angle_penalty: 0.3
    
    # 最小距离惩罚 - 确保距离惩罚不会过大的最小惩罚值，防止重定位时位置变化过大
    minimum_distance_penalty: 0.3
    
    # 是否启用闭环检测 - 必须启用才能支持重定位功能
    do_loop_closing: false
    
    # # 是否启用交互模式
    enable_interactive_mode: false
    # interactive_mode: false
    
    # # 暂停新测量处理
    # paused_new_measurements: false
    
    # # 暂停处理
    # paused_processing: false
    
    # 位置协方差缩放 - 控制位置估计的不确定性，值越小表示对位置估计越自信
    position_covariance_scale: 0.1
    
    # 偏航角协方差缩放 - 控制角度估计的不确定性，值越小表示对角度估计越自信
    yaw_covariance_scale: 0.1
    
    # 分辨率 - 地图分辨率
    resolution: 0.05
    
    # 占用阈值 - 标记为占用的单元格的光束命中率与光束通过率的最小比率
    # 稀疏点云场景降低阈值，使障碍物更容易被标记（黑色区域）
    occupancy_threshold: 0.1
    
    # # 地图名称
    map_name: "map"
    
    # 最小时间间隔 - 扫描处理间隔，降低频率以减少计算负载，提高长距离稳定性
    # 稀疏扫描时提高处理频率，积累更多证据以标记障碍物
    minimum_time_interval: 0.1
    
    # 最小移动距离 - 触发地图更新的最小距离，增加距离阈值以减少频繁更新
    # 稀疏扫描时降低距离阈值，更灵敏地触发地图更新
    minimum_travel_distance: 0.1
    
    # 最小移动角度 - 触发地图更新的最小角度，增加角度阈值以减少频繁更新
    # 稀疏扫描时降低角度阈值，旋转时也及时更新地图
    minimum_travel_heading: 0.04
    
    # 扫描缓冲区大小 - 增加缓冲区大小以支持更长的匹配距离，提高长距离稳定性
    scan_buffer_size: 2000
    
    # 扫描队列大小 - 控制扫描数据的处理队列
    scan_queue_size: 100
    
    # 扫描缓冲区最大扫描距离 - 增加匹配距离范围，提高重定位能力
    scan_buffer_maximum_scan_distance: 50.0
    
    # # 最小通过距离 - 在单元格被标记为占用或未占用之前必须通过的光束数量
    # min_pass_through: 0.0
    
    # # 链接扫描最小响应（精细）
    # link_match_minimum_response_fine: 0.1
    
    # # 链接扫描最大距离
    # link_scan_maximum_distance: 10.0
    
    # 闭环匹配最大方差（粗略） - 控制闭环检测的匹配阈值，值越小匹配越严格
    loop_match_maximum_variance_coarse: 0.4
    
    # 闭环匹配最小链大小 - 检测闭环所需的最小连续匹配数
    loop_match_minimum_chain_size: 3
    
    # 闭环匹配最小响应（粗略） - 粗略匹配的最小响应阈值
    loop_match_minimum_response_coarse: 0.3
    
    # 闭环匹配最小响应（精细） - 精细匹配的最小响应阈值
    loop_match_minimum_response_fine: 0.1
    
    # 闭环搜索最大距离 - 增加搜索距离范围以支持更长的匹配，提高重定位能力
    loop_search_maximum_distance: 15.0
    
    # 闭环搜索空间维度 - 适当增加搜索空间尺寸以支持更长的匹配距离
    loop_search_space_dimension: 0.25
    
    # 闭环搜索空间分辨率 - 略微降低分辨率以减少计算负载，平衡性能
    loop_search_space_resolution: 0.008
    
    # 闭环搜索空间模糊偏差 - 用于平滑响应的多模态模糊量
    loop_search_space_smear_deviation: 0.025
    
    # 相关搜索空间维度 - 增加搜索空间尺寸以支持更长的匹配距离
    correlation_search_space_dimension: 0.4
    
    # 相关搜索空间分辨率 - 略微降低分辨率以减少计算负载，平衡性能
    correlation_search_space_resolution: 0.008
    
    # 相关搜索空间模糊偏差 - 相关匹配的模糊偏差
    correlation_search_space_smear_deviation: 0.025
    
    # 粗略角度分辨率 - 在扫描匹配中测试角度偏移范围的角度分辨率
    coarse_angle_resolution: 0.0174532925
    
    # 粗略搜索角度偏移 - 用于粗略扫描匹配的角度测试范围
    coarse_search_angle_offset: 0.0
    
    # 精细搜索角度偏移 - 用于精细扫描匹配的角度测试范围
    fine_search_angle_offset: 0.00174532925
    
    # 是否使用扫描重心 - 使用扫描重心进行匹配，提高重定位精度
    use_scan_barycenter: true
    
    # 是否使用响应扩展 - 如果未找到可行匹配，是否自动增加搜索网格大小，重定位时建议启用
    use_response_expansion: true
    
    # # 是否启用调试日志
    debug_logging: false
    
    # # 限制扫描频率
    throttle_scans: 1
    
    # # 变换超时
    transform_timeout: 0.5
    
    # # TF缓冲区持续时间
    tf_buffer_duration: 5.0
    
    # # 求解器插件 - 用于karto扫描求解器的非线性求解器类型
    # # 选项: solver_plugins::CeresSolver, solver_plugins::SpaSolver, solver_plugins::G2oSolver
    # # 默认: solver_plugins::CeresSolver
    # solver_plugin: "CeresSolver"
    
    # # Ceres求解器参数
    # # Ceres线性求解器 - Ceres使用的线性求解器
    # # 选项: SPARSE_NORMAL_CHOLESKY, SPARSE_SCHUR, ITERATIVE_SCHUR, CGNR
    # # 默认: SPARSE_NORMAL_CHOLESKY
    # ceres_linear_solver: "SPARSE_NORMAL_CHOLESKY"
    
    # # Ceres预处理器 - 与求解器一起使用的预处理器
    # # 选项: JACOBI, IDENTITY (无), SCHUR_JACOBI
    # # 默认: JACOBI
    # ceres_preconditioner: "JACOBI"
    
    # # Ceres信任区域策略 - 信任区域策略
    # # 选项: LEVENBERG_MARQUARDT, DOGLEG
    # # 默认: LEVENBERG_MARQUARDT
    # ceres_trust_strategy: "LEVENBERG_MARQUARDT"
    
    # # Ceres狗腿类型 - 如果信任策略是DOGLEG时使用的狗腿策略
    # # 选项: TRADITIONAL_DOGLEG, SUBSPACE_DOGLEG
    # # 默认: TRADITIONAL_DOGLEG
    # ceres_dogleg_type: "TRADITIONAL_DOGLEG"
    
    # # Ceres损失函数 - 用于拒绝异常值测量的损失函数类型
    # # 选项: None (等价于平方损失), HuberLoss, CauchyLoss
    # # 默认: None
    # ceres_loss_function: "Cauchy"

    # # QoS 参数配置 - 消息服务质量设置
    # qos_overrides:
    #   # 时钟话题订阅配置
    #   ./clock:
    #     subscription:
    #       depth: 10
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "reliable"
      
    #   # 参数事件发布配置
    #   ./parameter_events:
    #     publisher:
    #       depth: 10
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "reliable"
      
    #   # TF 发布配置
    #   ./tf:
    #     publisher:
    #       depth: 10
    #       durability: "volatile"
    #       history: "keep_last"
    #       reliability: "reliable"
