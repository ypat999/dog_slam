[Unit]
Description=LIO-SAM NAV2 Navigation Service
After=network.target rmw_control.service
Wants=network.target rmw_control.service

[Service]
Type=simple
User=ztl
Group=ztl
WorkingDirectory=/home/ztl/dog_slam/LIO-SAM_MID360_ROS2_PKG/
Environment="ROS_DOMAIN_ID=24"
Environment="RMW_IMPLEMENTATION=rmw_zenoh_cpp"
ExecStart=/home/ztl/dog_slam/LIO-SAM_MID360_ROS2_PKG/scripts/run_navigation.sh no_lio
ExecStop=/home/ztl/dog_slam/LIO-SAM_MID360_ROS2_PKG/scripts/stop_all_navs.sh
Restart=always
RestartSec=10
TimeoutStopSec=10
KillMode=control-group
SendSIGKILL=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
